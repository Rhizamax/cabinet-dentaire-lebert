---
// src/components/Footer.astro
import { CABINET, NAV_LINKS, url } from "../config";
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <img src={url("/images/logo.png")} alt={CABINET.nom} width="80" height="120" class="footer-logo" />
      <p>{CABINET.nom}</p>
    </div>

    <nav aria-label="Liens de navigation rapide">
      <h3>Navigation</h3>
      <ul>
        {NAV_LINKS.map((link) => (
          <li><a href={url(link.href)}>{link.label}</a></li>
        ))}
      </ul>
    </nav>

    <div>
      <h3>Horaires</h3>
      <ul class="plain-list">
        {CABINET.horaires.map((h) => (
          <li>{h.jours} : {h.heures}</li>
        ))}
      </ul>
      <p class="note">{CABINET.horairesNote}</p>
    </div>

    <div>
      <h3>Contact</h3>
      <address>
        {CABINET.adresse.ligne1}<br />
        {CABINET.adresse.ligne2}
      </address>
      <p><a href={CABINET.telephoneTel}>{CABINET.telephone}</a></p>
      <p><a href={`mailto:${CABINET.email}`}>{CABINET.email}</a></p>
      
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <p>© {year} {CABINET.nom}. Tous droits réservés.</p>
      <a href={url("/mentions-legales")}>Mentions légales</a>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-primary-light);
    border-top: 1px solid var(--color-border);
    padding-top: 3rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.3fr 1fr 1fr 1.2fr;
    gap: 2.5rem;
    padding-bottom: 2.5rem;
  }

  .footer-brand { display: flex; flex-direction: column; gap: 0.75rem; }
  .footer-logo { height: 80px; width: 120px; }
  .footer-brand p {
    font-family: var(--font-heading);
    font-weight: 600;
    color: var(--color-primary-dark);
    margin: 0;
  }

  h3 {
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-secondary-dark);
    margin-bottom: 0.9em;
  }

  .footer-grid ul { list-style: none; margin: 0; padding: 0; }
  .footer-grid li { margin-bottom: 0.55em; }
  .plain-list li { color: var(--color-text); }

  address { font-style: normal; margin-bottom: 0.6em; color: var(--color-text); }

  .note { font-size: 0.82rem; color: var(--color-text-muted); margin-top: 0.4em; }

  .btn-outline-primary { margin-top: 0.5em; }

  .footer-bottom {
    border-top: 1px solid var(--color-border);
    background: rgba(255,255,255,0.5);
  }
  .footer-bottom-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding: 1.25rem 1.5rem;
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }
  .footer-bottom-inner a { color: var(--color-text-muted); text-decoration: underline; }

  @media (max-width: 900px) {
    .footer-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 540px) {
    .footer-grid { grid-template-columns: 1fr; }
  }
</style>
