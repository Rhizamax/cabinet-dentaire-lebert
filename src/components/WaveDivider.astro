---
// src/components/WaveDivider.astro
// Élément signature : reprend le tracé en dégradé bleu→sarcelle du logo,
// utilisé comme séparateur de section pour ancrer l'identité de marque.
interface Props {
  flip?: boolean;
}
const { flip = false } = Astro.props;
---

<div class:list={["wave-divider", { flip }]} aria-hidden="true">
  <svg viewBox="0 0 1200 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
    <defs>
      <linearGradient id="waveGradient" x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%" stop-color="var(--color-primary)" />
        <stop offset="100%" stop-color="var(--color-secondary)" />
      </linearGradient>
    </defs>
    <path d="M0,30 C300,70 900,-10 1200,30 L1200,60 L0,60 Z" fill="url(#waveGradient)" opacity="0.9" />
  </svg>
</div>

<style>
  .wave-divider {
    line-height: 0;
    transform: scaleY(1);
  }
  .wave-divider.flip {
    transform: scaleY(-1);
  }
  .wave-divider svg {
    width: 100%;
    height: 36px;
    display: block;
  }
</style>
