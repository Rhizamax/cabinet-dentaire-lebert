---
// src/layouts/SoinLayout.astro
import BaseLayout from "./BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import { CABINET, url } from "../config";
import Icon from "../components/Icon.astro";

interface Props {
  title: string;
  description: string;
  eyebrow?: string;
}
const { title, description, eyebrow = "Soins dentaires" } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <PageHero eyebrow={eyebrow} title={title} />

  <section class="section">
    <div class="container soin-content">
      <div class="soin-article">
        <slot />
      </div>

      <aside class="soin-aside">
        <div class="aside-card">
          <h2>Une question ?</h2>
          <p>Notre équipe est à votre écoute pour toute question sur ce soin.</p>
          
          <a href={CABINET.telephoneTel} class="btn btn-outline-primary">
            <Icon name="phone" size={18} /> {CABINET.telephone}
          </a>
          <a href={url("/soins-dentaires")} class="back-link">← Retour aux soins dentaires</a>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .soin-content {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 3rem;
    align-items: start;
  }

  .soin-article :global(h2) {
    margin-top: 1.8em;
    font-size: 1.35rem;
  }
  .soin-article :global(h2:first-child) { margin-top: 0; }
  .soin-article :global(p) { color: var(--color-text); }
  .soin-article :global(ul),
  .soin-article :global(ol) {
    color: var(--color-text);
    padding-left: 1.3em;
  }
  .soin-article :global(li) { margin-bottom: 0.5em; }
  .soin-article :global(strong) { color: var(--color-primary-dark); }
  .soin-article :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5em 0;
    font-size: 0.92rem;
  }
  .soin-article :global(th),
  .soin-article :global(td) {
    border: 1px solid var(--color-border);
    padding: 0.6em 0.8em;
    text-align: left;
  }
  .soin-article :global(th) {
    background: var(--color-primary-light);
    color: var(--color-primary-dark);
    font-family: var(--font-heading);
  }
  .soin-article :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2em 0;
  }

  .aside-card {
    position: sticky;
    top: calc(var(--header-height) + 1.5rem);
    background: var(--color-primary-light);
    border-radius: var(--radius-card);
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  .aside-card h2 { font-size: 1.1rem; margin-bottom: 0.1em; }
  .aside-card p { color: var(--color-text-muted); font-size: 0.92rem; margin-bottom: 0.3em; }
  .back-link {
    font-size: 0.88rem;
    color: var(--color-primary);
    margin-top: 0.3rem;
  }

  @media (max-width: 900px) {
    .soin-content { grid-template-columns: 1fr; }
    .aside-card { position: static; }
  }
</style>
